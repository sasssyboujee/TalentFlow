  file_change {
    absolute_path_uri: "file:///src/components/Dashboard.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useMemo } from \'react\';\nimport { useAppState } from \'../state\';\nimport { Target, CheckCircle2, RotateCw, XCircle, Briefcase, TrendingUp } from \'lucide-react\';\n\nexport function Dashboard() {\n  const { applications, setView } = useAppState();\n\n  const stats = useMemo(() => {\n    const total = applications.length;\n    const applied = applications.filter(a => a.status === \'applied\' || a.status === \'interview\' || a.status === \'offer\' || a.status === \'rejected\').length;\n    const interviewing = applications.filter(a => a.status === \'interview\').length;\n    const active = applications.filter(a => a.status === \'queued\' || a.status === \'scraping\' || a.status === \'tailoring\' || a.status === \'ready\').length;\n    \n    return { total, applied, interviewing, active };\n  }, [applications]);\n\n  return (\n    <div className=\"p-8 max-w-6xl mx-auto space-y-8\">\n      <header>\n        <h1 className=\"text-3xl font-display font-bold text-slate-900 tracking-tight\">Overview</h1>\n        <p className=\"text-slate-500 mt-1\">Your automated agent activity and job pipeline.</p>\n      </header>\n\n      <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4\">\n        <StatCard title=\"Total Tracked\" value={stats.total} icon={Briefcase} trend=\"+3 this week\" />\n        <StatCard title=\"Auto-Applied\" value={stats.applied} icon={CheckCircle2} trend=\"85% success rate\" color=\"text-green-600\" />\n        <StatCard title=\"Active Processing\" value={stats.active} icon={RotateCw} color=\"text-blue-600\" />\n        <StatCard title=\"Interviews\" value={stats.interviewing} icon={Target} color=\"text-indigo-600\" />\n      </div>\n\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        <div className=\"lg:col-span-2 bg-white rounded-xl border border-slate-200 shadow-sm p-6\">\n          <div className=\"flex items-center justify-between mb-6\">\n            <h3 className=\"font-semibold text-slate-800\">Recent Agent Activity</h3>\n            <button \n              onClick={() => setView(\'tracker\')}\n              className=\"text-sm text-indigo-600 font-medium hover:text-indigo-700\"\n            >\n              View Pipeline &rarr;\n            </button>\n          </div>\n          <div className=\"space-y-4\">\n            {applications.slice(0, 5).map(app => (\n              <div key={app.id} className=\"flex items-center justify-between p-4 rounded-lg bg-slate-50 border border-slate-100\">\n                <div className=\"flex flex-col\">\n                  <span className=\"font-medium text-slate-900\">{app.role}</span>\n                  <span className=\"text-sm text-slate-500\">{app.company}</span>\n                </div>\n                <div className=\"flex items-center gap-4\">\n                  {app.matchScore && (\n                    <div className=\"flex flex-col items-end\">\n                      <span className=\"text-xs font-mono text-slate-400\">FAISS MATCH</span>\n                      <span className=\"text-sm font-semibold text-indigo-600\">{app.matchScore}%</span>\n                    </div>\n                  )}\n                  <span className=\"px-2.5 py-1 text-xs font-medium bg-slate-200 text-slate-700 rounded-full capitalize\">\n                    {app.status}\n                  </span>\n                </div>\n              </div>\n            ))}\n            {applications.length === 0 && (\n              <div className=\"text-center py-8 text-slate-500\">No applications tracked yet.</div>\n            )}\n          </div>\n        </div>\n\n        <div className=\"bg-slate-900 rounded-xl shadow-sm p-6 text-slate-100\">\n          <h3 className=\"font-semibold text-white mb-2\">Vector DB Status</h3>\n          <p className=\"text-sm text-slate-400 mb-6\">Local FAISS index for profile matching is healthy.</p>\n          \n          <div className=\"space-y-4 font-mono text-xs\">\n            <div className=\"flex justify-between border-b border-slate-800 pb-2\">\n              <span className=\"text-slate-500\">Index Size</span>\n              <span className=\"text-slate-300\">12.4 MB</span>\n            </div>\n            <div className=\"flex justify-between border-b border-slate-800 pb-2\">\n              <span className=\"text-slate-500\">Document Chunks</span>\n              <span className=\"text-slate-300\">2,408</span>\n            </div>\n            <div className=\"flex justify-between border-b border-slate-800 pb-2\">\n              <span className=\"text-slate-500\">LLM Engine</span>\n              <span className=\"text-slate-300\">Active</span>\n            </div>\n          </div>\n\n          <button \n            onClick={() => setView(\'runner\')}\n            className=\"w-full mt-8 bg-indigo-500 hover:bg-indigo-600 text-white shadow font-medium py-2 px-4 rounded-lg transition-colors flex items-center justify-center gap-2\"\n          >\n            Launch Agent <TrendingUp className=\"w-4 h-4\" />\n          </button>\n        </div>\n      </div>\n    </div>\n  );\n}\n\nfunction StatCard({ title, value, icon: Icon, trend, color = \"text-slate-600\" }: any) {\n  return (\n    <div className=\"bg-white rounded-xl border border-slate-200 shadow-sm p-5 flex flex-col\">\n      <div className=\"flex items-center justify-between mb-4\">\n        <h3 className=\"text-sm font-medium text-slate-500\">{title}</h3>\n        <Icon className={`w-5 h-5 ${color}`} />\n      </div>\n      <div className=\"text-3xl font-display font-bold text-slate-900\">{value}</div>\n      {trend && (\n        <div className=\"mt-2 text-xs font-medium text-slate-400\">{trend}</div>\n      )}\n    </div>\n  );\n}"
    }
