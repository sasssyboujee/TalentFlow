    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React from \'react\';\nimport { useAppState } from \'../state\';\nimport { ExternalLink, MoreVertical } from \'lucide-react\';\nimport type { JobApplication, ApplicationStatus } from \'../types\';\n\nconst COLUMNS: { id: ApplicationStatus; label: string; color: string }[] = [\n  { id: \'queued\', label: \'Queued\', color: \'bg-slate-100\' },\n  { id: \'ready\', label: \'Ready to Apply\', color: \'bg-blue-50\' },\n  { id: \'applied\', label: \'Applied\', color: \'bg-indigo-50\' },\n  { id: \'interview\', label: \'Interview\', color: \'bg-green-50\' },\n  { id: \'rejected\', label: \'Rejected\', color: \'bg-red-50\' },\n];\n\nexport function JobTracker() {\n  const { applications, updateApplicationStatus } = useAppState();\n\n  const getAppsByStatus = (status: ApplicationStatus) => \n    applications.filter(app => app.status === status);\n\n  return (\n    <div className=\"p-8 h-full flex flex-col\">\n      <header className=\"mb-8 shrink-0\">\n        <h1 className=\"text-3xl font-display font-bold text-slate-900 tracking-tight\">Job Tracker</h1>\n        <p className=\"text-slate-500 mt-1\">Manage and track your automated applications.</p>\n      </header>\n\n      <div className=\"flex-1 flex gap-6 overflow-x-auto pb-4\">\n        {COLUMNS.map(col => {\n          const apps = getAppsByStatus(col.id);\n          \n          return (\n            <div key={col.id} className={`w-80 shrink-0 rounded-xl flex flex-col ${col.color} border border-slate-200/50`}>\n              <div className=\"p-4 border-b border-slate-200/50 flex justify-between items-center shrink-0\">\n                <h3 className=\"font-medium text-slate-800\">{col.label}</h3>\n                <span className=\"text-xs font-semibold bg-white/50 px-2 py-1 rounded-full text-slate-600\">\n                  {apps.length}\n                </span>\n              </div>\n              <div className=\"p-4 flex-1 overflow-y-auto space-y-4\">\n                {apps.map(app => (\n                  <JobCard key={app.id} app={app} onStatusChange={(newStatus) => updateApplicationStatus(app.id, newStatus)} />\n                ))}\n              </div>\n            </div>\n          );\n        })}\n      </div>\n    </div>\n  );\n}\n\nfunction JobCard({ app, onStatusChange }: { app: JobApplication, onStatusChange: (s: ApplicationStatus) => void }) {\n  return (\n    <div className=\"bg-white p-4 rounded-lg shadow-sm border border-slate-200 hover:shadow-md transition-shadow\">\n      <div className=\"flex justify-between items-start mb-2\">\n        <h4 className=\"font-semibold text-slate-900 line-clamp-1\" title={app.role}>{app.role}</h4>\n        <div className=\"relative group\">\n          <button className=\"text-slate-400 hover:text-slate-600\">\n            <MoreVertical className=\"w-4 h-4\" />\n          </button>\n          \n          {/* Simple Dropdown for Status Change */}\n          <div className=\"absolute right-0 top-6 w-36 bg-white border border-slate-200 shadow-lg rounded-md hidden group-hover:block z-10 py-1\">\n            <div className=\"px-3 py-1 text-xs font-semibold text-slate-500 uppercase tracking-wider\">Move to</div>\n            {COLUMNS.map(c => (\n              <button \n                key={c.id} \n                onClick={() => onStatusChange(c.id)}\n                className={`w-full text-left px-3 py-1.5 text-sm hover:bg-slate-50 ${app.status === c.id ? \'text-indigo-600 font-medium\' : \'text-slate-700\'}`}\n              >\n                {c.label}\n              </button>\n            ))}\n          </div>\n        </div>\n      </div>\n      <p className=\"text-sm text-slate-500 mb-4\">{app.company}</p>\n      \n      {app.matchScore && (\n        <div className=\"mb-3\">\n          <div className=\"flex justify-between text-xs mb-1\">\n            <span className=\"text-slate-500 line-clamp-1\" title=\"FAISS Document Match\">Vector Match</span>\n            <span className=\"font-medium text-indigo-600\">{app.matchScore}%</span>\n          </div>\n          <div className=\"h-1.5 w-full bg-slate-100 rounded-full overflow-hidden\">\n            <div className=\"h-full bg-indigo-500 rounded-full\" style={{ width: `${app.matchScore}%` }} />\n          </div>\n        </div>\n      )}\n\n      {app.extractedKeywords && app.extractedKeywords.length > 0 && (\n        <div className=\"flex flex-wrap gap-1 mb-4\">\n          {app.extractedKeywords.slice(0, 3).map(kw => (\n            <span key={kw} className=\"px-1.5 py-0.5 bg-slate-100 text-slate-500 text-[10px] uppercase font-mono tracking-tighter rounded\">\n              {kw}\n            </span>\n          ))}\n          {app.extractedKeywords.length > 3 && (\n            <span className=\"px-1.5 py-0.5 bg-slate-100 text-slate-500 text-[10px] uppercase font-mono tracking-tighter rounded\">\n              +{app.extractedKeywords.length - 3}\n            </span>\n          )}\n        </div>\n      )}\n\n      <div className=\"flex justify-between items-center text-xs text-slate-400\">\n        <span className=\"font-mono\">{new Date(app.dateAdded).toLocaleDateString()}</span>\n        <a href={app.url} target=\"_blank\" rel=\"noopener noreferrer\" className=\"flex items-center gap-1 hover:text-indigo-600 transition-colors\">\n          View JD <ExternalLink className=\"w-3 h-3\" />\n        </a>\n      </div>\n    </div>\n  );\n}"
    }
