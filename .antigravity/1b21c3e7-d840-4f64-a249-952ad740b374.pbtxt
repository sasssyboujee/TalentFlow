  file_change {
    absolute_path_uri: "file:///src/components/AgentRunner.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState, useRef, useEffect } from \'react\';\nimport { useAppState } from \'../state\';\nimport { Terminal, Crosshair, Cpu, FileCheck, CheckCircle2, Loader2, ArrowRight } from \'lucide-react\';\nimport clsx from \'clsx\';\nimport type { AgentLog } from \'../types\';\n\nexport function AgentRunner() {\n  const { addApplication, setView } = useAppState();\n  const [url, setUrl] = useState(\'\');\n  const [isRunning, setIsRunning] = useState(false);\n  const [logs, setLogs] = useState<AgentLog[]>([]);\n  const [currentStep, setCurrentStep] = useState(0);\n  const logsEndRef = useRef<HTMLDivElement>(null);\n\n  const steps = [\n    { id: \'scrape\', label: \'Selenium DOM Scrape\', icon: Crosshair },\n    { id: \'vector\', label: \'FAISS Vector Match\', icon: Cpu },\n    { id: \'tailor\', label: \'LLM Synthesis\', icon: FileCheck },\n    { id: \'pdf\', label: \'PDF Generation\', icon: CheckCircle2 },\n  ];\n\n  const pushLog = (msg: string, type: AgentLog[\'type\'] = \'info\') => {\n    setLogs(prev => [...prev, {\n      id: Math.random().toString(),\n      timestamp: new Date().toLocaleTimeString(),\n      message: msg,\n      type\n    }]);\n  };\n\n  useEffect(() => {\n    if (logsEndRef.current) {\n      logsEndRef.current.scrollIntoView({ behavior: \'smooth\' });\n    }\n  }, [logs]);\n\n  const handleRunAgent = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!url) return;\n\n    setIsRunning(true);\n    setLogs([]);\n    setCurrentStep(0);\n    \n    // Simulate Agent Pipeline\n    pushLog(`Initializing headless browser for ${url}...`);\n    \n    await new Promise(r => setTimeout(r, 1500));\n    pushLog(`Bypassing bot detection and rendering client-side JS...`, \'warning\');\n    \n    await new Promise(r => setTimeout(r, 2000));\n    pushLog(`DOM Scraped successfully. Extracting raw text nodes.`, \'success\');\n    setCurrentStep(1);\n    \n    await new Promise(r => setTimeout(r, 1000));\n    pushLog(`Target role identified: \"Senior AI Engineer\" at \"MockCompany Inc.\"`);\n    pushLog(`Chunking JD text and querying local FAISS profile vector store...`);\n    \n    await new Promise(r => setTimeout(r, 2500));\n    pushLog(`Vector match score: 87%. Missing keywords: \'PyTorch\', \'REST API\'.`, \'warning\');\n    setCurrentStep(2);\n    \n    await new Promise(r => setTimeout(r, 1500));\n    pushLog(`Dispatched prompt to LangChain backend for resume tailoring...`);\n    \n    await new Promise(r => setTimeout(r, 3000));\n    pushLog(`Bullets rewritten to emphasize mathematical modeling & REST APIs.`, \'success\');\n    setCurrentStep(3);\n    \n    await new Promise(r => setTimeout(r, 1500));\n    pushLog(`Compiling clean HTML string...`);\n    pushLog(`Invoking Page.printToPDF via DevTools Protocol...`);\n    \n    await new Promise(r => setTimeout(r, 2000));\n    pushLog(`Aesthetic PDF Output generated and saved to /dist/resumes/`, \'success\');\n    pushLog(`Auto-submit application workflow engaged...`);\n\n    await new Promise(r => setTimeout(r, 2000));\n    \n    const newApp = {\n      id: `app-${Date.now()}`,\n      company: \'MockCompany Inc.\',\n      role: \'Senior AI Engineer\',\n      url,\n      status: \'applied\' as const,\n      dateAdded: new Date().toISOString(),\n      matchScore: 87,\n      extractedKeywords: [\'Python\', \'PyTorch\', \'Vector DB\', \'REST API\'],\n      agentLogs: logs\n    };\n    \n    addApplication(newApp);\n    pushLog(`Application successfully submitted! Tracking via Dashboard.`, \'success\');\n    \n    setTimeout(() => {\n      setIsRunning(false);\n      setUrl(\'\');\n      setView(\'tracker\');\n    }, 2000);\n  };\n\n  return (\n    <div className=\"p-8 max-w-5xl mx-auto h-full flex flex-col\">\n      <header className=\"mb-8 shrink-0\">\n        <h1 className=\"text-3xl font-display font-bold text-slate-900 tracking-tight\">Agent Runner</h1>\n        <p className=\"text-slate-500 mt-1\">Deploy the AI agent to scrape, tailor, and apply to a specific job listing.</p>\n      </header>\n\n      <div className=\"flex-1 grid grid-cols-1 lg:grid-cols-2 gap-8 min-h-0\">\n        {/* Left Column: Form & Steps */}\n        <div className=\"flex flex-col gap-6\">\n          <div className=\"bg-white p-6 rounded-xl border border-slate-200 shadow-sm shrink-0\">\n            <form onSubmit={handleRunAgent}>\n              <label className=\"block text-sm font-medium text-slate-700 mb-2\">Target Job URL</label>\n              <div className=\"flex gap-3\">\n                <input\n                  type=\"url\"\n                  required\n                  placeholder=\"https://company.com/jobs/...\"\n                  value={url}\n                  onChange={e => setUrl(e.target.value)}\n                  disabled={isRunning}\n                  className=\"flex-1 px-4 py-2 bg-slate-50 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all disabled:opacity-50\"\n                />\n                <button\n                  type=\"submit\"\n                  disabled={isRunning || !url}\n                  className=\"bg-indigo-600 hover:bg-indigo-700 disabled:bg-slate-400 text-white px-6 py-2 rounded-lg font-medium shadow-sm transition-all flex items-center gap-2\"\n                >\n                  {isRunning ? <Loader2 className=\"w-5 h-5 animate-spin\" /> : <Terminal className=\"w-5 h-5\" />}\n                  {isRunning ? \'Running...\' : \'Deploy Agent\'}\n                </button>\n              </div>\n            </form>\n          </div>\n\n          <div className=\"bg-white p-6 rounded-xl border border-slate-200 shadow-sm flex-1 flex flex-col\">\n            <h3 className=\"font-semibold text-slate-900 mb-6\">Pipeline Status</h3>\n            <div className=\"space-y-6 relative flex-1\">\n              <div className=\"absolute left-4 top-4 bottom-4 w-px bg-slate-100 z-0\"></div>\n              {steps.map((step, idx) => {\n                const Icon = step.icon;\n                const status = idx < currentStep ? \'complete\' : idx === currentStep && isRunning ? \'active\' : \'pending\';\n                \n                return (\n                  <div key={step.id} className=\"relative z-10 flex items-start gap-4\">\n                    <div className={clsx(\n                      \"w-8 h-8 rounded-full flex items-center justify-center shrink-0 border-2 transition-colors\",\n                      status === \'complete\' ? \"bg-indigo-50 border-indigo-500 text-indigo-600\" :\n                      status === \'active\' ? \"bg-white border-indigo-500 text-indigo-600\" :\n                      \"bg-slate-50 border-slate-200 text-slate-400\"\n                    )}>\n                      {status === \'active\' ? <Loader2 className=\"w-4 h-4 animate-spin\" /> : <Icon className=\"w-4 h-4\" />}\n                    </div>\n                    <div className=\"pt-1\">\n                      <p className={clsx(\n                        \"font-medium\",\n                        status === \'pending\' ? \"text-slate-400\" : \"text-slate-900\"\n                      )}>{step.label}</p>\n                    </div>\n                  </div>\n                );\n              })}\n            </div>\n          </div>\n        </div>\n\n        {/* Right Column: Terminal Logs */}\n        <div className=\"bg-slate-950 rounded-xl shadow-xl flex flex-col overflow-hidden border border-slate-800\">\n          <div className=\"px-4 py-3 border-b border-slate-800 bg-slate-900 flex items-center gap-2 shrink-0\">\n            <Terminal className=\"w-4 h-4 text-slate-400\" />\n            <span className=\"text-xs font-mono text-slate-400\">agent-console</span>\n          </div>\n          <div className=\"p-4 flex-1 overflow-y-auto font-mono text-sm\">\n            {logs.length === 0 ? (\n              <div className=\"text-slate-600 italic\">Waiting for command...</div>\n            ) : (\n              <div className=\"space-y-2\">\n                {logs.map(log => (\n                  <div key={log.id} className=\"flex items-start gap-4\">\n                    <span className=\"text-slate-500 shrink-0\">[{log.timestamp}]</span>\n                    <span className={clsx(\n                      \"break-words\",\n                      log.type === \'success\' ? \"text-green-400\" :\n                      log.type === \'warning\' ? \"text-yellow-400\" :\n                      log.type === \'error\' ? \"text-red-400\" :\n                      \"text-slate-300\"\n                    )}>\n                      {log.message}\n                    </span>\n                  </div>\n                ))}\n                <div ref={logsEndRef} />\n              </div>\n            )}\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}"
    }
